<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MauiClient.ViewModels"
             x:Class="MauiClient.Views.HealthPage"
             x:DataType="vm:HealthViewModel"
             Title="{Binding Title}">

    <ScrollView>
        <VerticalStackLayout Spacing="16" Padding="24,32">

            <!-- Page heading -->
            <Label Text="Health"
                   Style="{StaticResource Headline}"
                   HorizontalOptions="Start" />

            <Label Text="Check the status of the Vision Service backend and its AI model endpoints."
                   Style="{StaticResource Caption}"
                   Margin="0,-8,0,8" />

            <!-- Action card -->
            <Border Style="{StaticResource SectionCard}">
                <VerticalStackLayout Spacing="16">
                    <Label Text="SERVICE STATUS"
                           Style="{StaticResource SectionHeading}" />

                    <Button Text="Check Health"
                            Command="{Binding CheckHealthCommand}"
                            IsEnabled="{Binding IsNotBusy}"
                            Style="{StaticResource AccentButton}"
                            HorizontalOptions="Start"
                            WidthRequest="160" />

                    <ActivityIndicator IsRunning="{Binding IsBusy}"
                                       IsVisible="{Binding IsBusy}"
                                       HorizontalOptions="Start"
                                       WidthRequest="24" HeightRequest="24" />
                </VerticalStackLayout>
            </Border>

            <!-- Results card -->
            <Border Style="{StaticResource SectionCard}"
                    IsVisible="{Binding ResultText, Converter={StaticResource StringNotEmptyConverter}}"
                    Stroke="{Binding HasError, Converter={StaticResource BoolToColorConverter}}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="RESULT"
                           Style="{StaticResource SectionHeading}" />
                    <Label Text="{Binding ResultText}"
                           Style="{StaticResource Mono}" />
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
