<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MauiClient.ViewModels"
             x:Class="MauiClient.Views.AdminPage"
             x:DataType="vm:AdminViewModel"
             Title="{Binding Title}">

    <ScrollView>
        <VerticalStackLayout Spacing="16" Padding="24,32">

            <!-- Page heading -->
            <Label Text="Admin"
                   Style="{StaticResource Headline}"
                   HorizontalOptions="Start" />

            <Label Text="Manage API keys for the Vision Service."
                   Style="{StaticResource Caption}"
                   Margin="0,-8,0,8" />

            <!-- ─── Existing Keys ────────────────────────────── -->
            <Border Style="{StaticResource SectionCard}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="API KEYS"
                           Style="{StaticResource SectionHeading}" />

                    <Button Text="List Keys"
                            Command="{Binding ListKeysCommand}"
                            IsEnabled="{Binding IsNotBusy}"
                            Style="{StaticResource AccentButton}"
                            HorizontalOptions="Start"
                            WidthRequest="140" />
                </VerticalStackLayout>
            </Border>

            <!-- ─── Create New Key ───────────────────────────── -->
            <Border Style="{StaticResource SectionCard}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="CREATE KEY"
                           Style="{StaticResource SectionHeading}" />

                    <Grid ColumnDefinitions="80,*" RowDefinitions="Auto,Auto,Auto"
                          ColumnSpacing="12" RowSpacing="10">
                        <Label Grid.Row="0" Grid.Column="0" Text="Name"
                               Style="{StaticResource FormLabel}" />
                        <Entry Grid.Row="0" Grid.Column="1"
                               Text="{Binding NewKeyName}"
                               Placeholder="e.g. dev-key"
                               ClearButtonVisibility="WhileEditing" />

                        <Label Grid.Row="1" Grid.Column="0" Text="Scopes"
                               Style="{StaticResource FormLabel}" />
                        <Entry Grid.Row="1" Grid.Column="1"
                               Text="{Binding NewKeyScopes}"
                               Placeholder="detect,analyze,admin"
                               ClearButtonVisibility="WhileEditing" />

                        <Label Grid.Row="2" Grid.Column="0" Text="RPM"
                               Style="{StaticResource FormLabel}" />
                        <Entry Grid.Row="2" Grid.Column="1"
                               Text="{Binding NewKeyRpm}"
                               Keyboard="Numeric"
                               Placeholder="60" />
                    </Grid>

                    <Button Text="Create"
                            Command="{Binding AddKeyCommand}"
                            IsEnabled="{Binding IsNotBusy}"
                            HorizontalOptions="Start"
                            WidthRequest="120" />

                    <ActivityIndicator IsRunning="{Binding IsBusy}"
                                       IsVisible="{Binding IsBusy}"
                                       HorizontalOptions="Start"
                                       WidthRequest="24" HeightRequest="24" />
                </VerticalStackLayout>
            </Border>

            <!-- ─── Results ──────────────────────────────────── -->
            <Border Style="{StaticResource SectionCard}"
                    IsVisible="{Binding ResultText, Converter={StaticResource StringNotEmptyConverter}}"
                    Stroke="{Binding HasError, Converter={StaticResource BoolToColorConverter}}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="RESULT"
                           Style="{StaticResource SectionHeading}" />
                    <Label Text="{Binding ResultText}"
                           Style="{StaticResource Mono}" />
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
