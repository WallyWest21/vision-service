<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MauiClient.ViewModels"
             x:Class="MauiClient.Views.LiveFeedPage"
             x:DataType="vm:LiveFeedViewModel"
             Title="{Binding Title}">

    <ScrollView>
        <VerticalStackLayout Spacing="16" Padding="24,32">

            <!-- Page heading -->
            <Label Text="Live Feed"
                   Style="{StaticResource Headline}"
                   HorizontalOptions="Start" />

            <Label Text="Stream from a camera and run real-time AI analysis on every frame."
                   Style="{StaticResource Caption}"
                   Margin="0,-8,0,8" />

            <!-- ─── Source Configuration ──────────────────────── -->
            <Border Style="{StaticResource SectionCard}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="SOURCE"
                           Style="{StaticResource SectionHeading}" />

                    <!-- Feed mode picker -->
                    <HorizontalStackLayout Spacing="12">
                        <Label Text="Mode"
                               Style="{StaticResource FormLabel}" />
                        <Picker ItemsSource="{Binding FeedModes}"
                                SelectedItem="{Binding SelectedFeedMode}"
                                WidthRequest="180"
                                VerticalOptions="Center" />
                    </HorizontalStackLayout>

                    <!-- URL entry (hidden in Local Camera mode) -->
                    <VerticalStackLayout Spacing="6"
                                         IsVisible="{Binding IsUrlMode}">
                        <Label Text="Stream URL"
                               Style="{StaticResource FormLabel}" />
                        <Entry Text="{Binding StreamUrl}"
                               Placeholder="http://camera-host/mjpeg  or  /snapshot.jpg"
                               ClearButtonVisibility="WhileEditing" />
                    </VerticalStackLayout>

                    <!-- Snapshot poll interval -->
                    <HorizontalStackLayout Spacing="12"
                                           IsVisible="{Binding IsSnapshotMode}">
                        <Label Text="Poll interval"
                               Style="{StaticResource FormLabel}" />
                        <Entry Text="{Binding PollIntervalMs, StringFormat='{0}'}"
                               Keyboard="Numeric"
                               WidthRequest="80"
                               VerticalOptions="Center" />
                        <Label Text="ms"
                               Style="{StaticResource Caption}"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>

                    <!-- Local camera device selection -->
                    <VerticalStackLayout Spacing="8"
                                         IsVisible="{Binding IsLocalCameraMode}">
                        <HorizontalStackLayout Spacing="12">
                            <Label Text="Camera"
                                   Style="{StaticResource FormLabel}" />
                            <Picker ItemsSource="{Binding CameraDevices}"
                                    SelectedItem="{Binding SelectedCameraDevice}"
                                    ItemDisplayBinding="{Binding Name}"
                                    WidthRequest="240"
                                    VerticalOptions="Center" />
                            <Button Text="Scan"
                                    Command="{Binding ScanCamerasCommand}"
                                    Style="{StaticResource SecondaryButton}"
                                    WidthRequest="80"
                                    VerticalOptions="Center" />
                            <ActivityIndicator IsRunning="{Binding IsScanningCameras}"
                                               IsVisible="{Binding IsScanningCameras}"
                                               WidthRequest="20" HeightRequest="20"
                                               VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- ─── AI Configuration ─────────────────────────── -->
            <Border Style="{StaticResource SectionCard}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="AI MODEL"
                           Style="{StaticResource SectionHeading}" />

                    <HorizontalStackLayout Spacing="12">
                        <Label Text="Mode"
                               Style="{StaticResource FormLabel}" />
                        <Picker ItemsSource="{Binding Modes}"
                                SelectedItem="{Binding SelectedMode}"
                                WidthRequest="150"
                                VerticalOptions="Center" />
                    </HorizontalStackLayout>

                    <!-- Confidence threshold -->
                    <HorizontalStackLayout Spacing="12"
                                           IsVisible="{Binding ShowConfidence}">
                        <Label Text="Confidence"
                               Style="{StaticResource FormLabel}" />
                        <Slider Minimum="0.1" Maximum="1.0"
                                Value="{Binding Confidence}"
                                WidthRequest="200"
                                VerticalOptions="Center" />
                        <Label Text="{Binding Confidence, StringFormat='{0:P0}'}"
                               Style="{StaticResource StatValue}"
                               WidthRequest="46" />
                    </HorizontalStackLayout>

                    <!-- Smart Query fields -->
                    <VerticalStackLayout Spacing="8"
                                         IsVisible="{Binding IsSmartQueryMode}">
                        <Label Text="Objects to watch for"
                               Style="{StaticResource FormLabel}" />
                        <Entry Text="{Binding ObjectQuery}"
                               Placeholder="e.g. person with red shirt, fire extinguisher"
                               ClearButtonVisibility="WhileEditing" />

                        <Label Text="System prompt"
                               Style="{StaticResource FormLabel}" />
                        <Editor Text="{Binding SystemPrompt}"
                                AutoSize="TextChanges"
                                MinimumHeightRequest="80"
                                FontSize="11"
                                FontFamily="Monospace" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- ─── Controls ─────────────────────────────────── -->
            <HorizontalStackLayout Spacing="12" HorizontalOptions="Start">
                <Button Text="Start"
                        Command="{Binding StartStreamCommand}"
                        Style="{StaticResource AccentButton}"
                        WidthRequest="140" />
                <Button Text="Stop"
                        Command="{Binding StopStreamCommand}"
                        Style="{StaticResource DangerButton}"
                        WidthRequest="140" />
            </HorizontalStackLayout>

            <!-- ─── Live Preview ─────────────────────────────── -->
            <Border StrokeShape="RoundRectangle 4"
                    StrokeThickness="1"
                    HeightRequest="400"
                    Padding="0"
                    BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray950}}">
                <Grid>
                    <Label Text="Waiting for frames…"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           Style="{StaticResource Caption}"
                           IsVisible="{Binding IsFrameNotAvailable}" />
                    <Image Source="{Binding CurrentFrame}"
                           Aspect="AspectFit"
                           IsVisible="{Binding IsFrameAvailable}" />
                    <GraphicsView x:Name="BoundingBoxOverlay"
                                  IsVisible="{Binding IsFrameAvailable}"
                                  HorizontalOptions="Fill"
                                  VerticalOptions="Fill"
                                  InputTransparent="True" />
                </Grid>
            </Border>

            <!-- ─── Live Metrics ─────────────────────────────── -->
            <Border Style="{StaticResource SectionCard}"
                    Padding="16,12"
                    IsVisible="{Binding IsStreaming}">
                <HorizontalStackLayout Spacing="24">
                    <Label Text="{Binding StatusText}"
                           Style="{StaticResource StatusLabel}"
                           TextColor="{StaticResource Success}" />
                    <Label Text="{Binding Fps, StringFormat='FPS {0:F1}'}"
                           Style="{StaticResource StatValue}" />
                    <Label Text="{Binding FrameCount, StringFormat='Frames {0:N0}'}"
                           Style="{StaticResource StatValue}" />
                    <Label Text="{Binding ProcessingTimeMs, StringFormat='AI {0:F0} ms'}"
                           Style="{StaticResource StatValue}" />
                </HorizontalStackLayout>
            </Border>

            <!-- ─── Results ──────────────────────────────────── -->
            <Border Style="{StaticResource SectionCard}"
                    IsVisible="{Binding ResultText, Converter={StaticResource StringNotEmptyConverter}}"
                    Stroke="{Binding HasError, Converter={StaticResource BoolToColorConverter}}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="ANALYSIS"
                           Style="{StaticResource SectionHeading}" />
                    <Label Text="{Binding ResultText}"
                           Style="{StaticResource Mono}" />
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
