<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!--
        Dieter Rams / Braun-inspired palette.
        Principle: restrained, warm neutrals with a single functional accent.
        "Less, but better."
    -->

    <!-- Brand — warm charcoal + functional orange accent (Braun TG 60 era) -->
    <Color x:Key="Primary">#2D2D2D</Color>
    <Color x:Key="PrimaryDark">#1A1A1A</Color>
    <Color x:Key="PrimaryDarkText">#F5F3F0</Color>
    <Color x:Key="Accent">#E86C2C</Color>
    <Color x:Key="AccentLight">#F4A97A</Color>
    <Color x:Key="Secondary">#E8E4DF</Color>
    <Color x:Key="SecondaryDarkText">#2D2D2D</Color>
    <Color x:Key="Tertiary">#5A5651</Color>

    <!-- Neutral scale — warm-tinted grays (not pure blue-gray) -->
    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="Black">#111111</Color>
    <Color x:Key="Gray50">#FAF9F7</Color>
    <Color x:Key="Gray100">#F0EEEB</Color>
    <Color x:Key="Gray200">#D9D6D1</Color>
    <Color x:Key="Gray300">#B8B4AE</Color>
    <Color x:Key="Gray400">#9A9590</Color>
    <Color x:Key="Gray500">#706B66</Color>
    <Color x:Key="Gray600">#4A4744</Color>
    <Color x:Key="Gray700">#36332F</Color>
    <Color x:Key="Gray900">#1E1D1B</Color>
    <Color x:Key="Gray950">#141312</Color>

    <!-- Surface tokens — card and page backgrounds -->
    <Color x:Key="SurfaceLight">#FAF9F7</Color>
    <Color x:Key="SurfaceDark">#1E1D1B</Color>
    <Color x:Key="CardLight">#FFFFFF</Color>
    <Color x:Key="CardDark">#2A2826</Color>
    <Color x:Key="CardStrokeLight">#E8E4DF</Color>
    <Color x:Key="CardStrokeDark">#3D3A37</Color>

    <!-- Semantic — softened to harmonise with warm palette -->
    <Color x:Key="Success">#3B8A4F</Color>
    <Color x:Key="Danger">#C0392B</Color>
    <Color x:Key="Warning">#D4A017</Color>
    <Color x:Key="Info">#4A90A4</Color>

</ResourceDictionary>
