{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "System.Net.Http": "Warning"
      }
    }
  },
  "Yolo": {
    "BaseUrl": "http://yolo-api:7860",
    "TimeoutSeconds": 30,
    "MaxRetries": 3
  },
  "QwenVl": {
    "BaseUrl": "http://qwen-vl:8000",
    "ModelName": "Qwen/Qwen2.5-VL-7B-Instruct",
    "MaxTokens": 1024,
    "Temperature": 0.7
  },
  "Storage": {
    "ImageStoragePath": "/data/images",
    "RetentionDays": 7,
    "MaxFileSizeMb": 20,
    "AllowedExtensions": [".jpg", ".jpeg", ".png", ".webp", ".bmp", ".gif"]
  },
  "Auth": {
    "Enabled": false,
    "ApiKeys": []
  },
  "RateLimit": {
    "RequestsPerMinute": 600,
    "BurstSize": 20
  },
  "Cache": {
    "Enabled": true,
    "DefaultTtlSeconds": 300,
    "MaxItems": 1000
  }
}
