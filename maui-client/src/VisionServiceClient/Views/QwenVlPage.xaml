<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VisionServiceClient.Views.QwenVlPage"
             Title="Vision-Language Model">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="12">
            <Label Text="Qwen-VL Vision-Language Analysis" FontSize="22" FontAttributes="Bold" />

            <Label Text="Mode:" FontAttributes="Bold" />
            <Picker ItemsSource="{Binding Modes}" SelectedItem="{Binding SelectedMode}" />

            <Button Text="Pick Image" Command="{Binding PickImageCommand}" />
            <Label Text="{Binding SelectedImagePath}"
                   FontSize="12"
                   TextColor="{StaticResource Gray500}"
                   LineBreakMode="TailTruncation" />

            <VerticalStackLayout IsVisible="{Binding ShowSecondImage}" Spacing="4">
                <Button Text="Pick Second Image (Compare)" Command="{Binding PickImage2Command}" />
                <Label Text="{Binding SelectedImage2Path}"
                       FontSize="12"
                       TextColor="{StaticResource Gray500}"
                       LineBreakMode="TailTruncation" />
            </VerticalStackLayout>

            <VerticalStackLayout IsVisible="{Binding ShowQuestion}" Spacing="4">
                <Label Text="Question:" FontAttributes="Bold" />
                <Entry Placeholder="What is in this image?" Text="{Binding Question}" />
            </VerticalStackLayout>

            <VerticalStackLayout IsVisible="{Binding ShowSystemPrompt}" Spacing="4">
                <Label Text="System Prompt:" FontAttributes="Bold" />
                <Editor Placeholder="Describe what analysis to perform..."
                        Text="{Binding SystemPrompt}"
                        AutoSize="TextChanges"
                        MinimumHeightRequest="80" />
            </VerticalStackLayout>

            <Button Text="Run Analysis"
                    Command="{Binding RunCommand}"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="White"
                    IsEnabled="{Binding IsNotBusy}" />
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" Color="{StaticResource Primary}" />
            <Label Text="{Binding StatusMessage}" TextColor="Green" />
            <Label Text="{Binding ErrorMessage}" TextColor="Red" />
            <Label Text="Result:" FontAttributes="Bold" />
            <Editor Text="{Binding ResultText}"
                    IsReadOnly="True"
                    AutoSize="TextChanges"
                    BackgroundColor="{StaticResource Gray100}"
                    MinimumHeightRequest="200" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
