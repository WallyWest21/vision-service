<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VisionServiceClient.Views.HealthPage"
             Title="Service Health">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">
            <Label Text="Service Health Check" FontSize="22" FontAttributes="Bold" />
            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="8" ColumnSpacing="12">
                <Label Grid.Row="0" Grid.Column="0" Text="Status:" FontAttributes="Bold" />
                <Label Grid.Row="0" Grid.Column="1" Text="{Binding HealthStatus}" />
                <Label Grid.Row="1" Grid.Column="0" Text="Service:" FontAttributes="Bold" />
                <Label Grid.Row="1" Grid.Column="1" Text="{Binding ServiceVersion}" />
                <Label Grid.Row="2" Grid.Column="0" Text="Last Checked:" FontAttributes="Bold" />
                <Label Grid.Row="2" Grid.Column="1" Text="{Binding LastChecked}" />
            </Grid>
            <Button Text="Check Health"
                    Command="{Binding CheckHealthCommand}"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="White"
                    IsEnabled="{Binding IsNotBusy}" />
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" Color="{StaticResource Primary}" />
            <Label Text="{Binding StatusMessage}" TextColor="Green" />
            <Label Text="{Binding ErrorMessage}" TextColor="Red" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
