<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VisionServiceClient.Views.SettingsPage"
             Title="Settings">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">
            <Label Text="Vision Service Settings" FontSize="22" FontAttributes="Bold" />
            <Label Text="Server Base URL" FontAttributes="Bold" />
            <Entry Placeholder="http://localhost:5100" Text="{Binding BaseUrl}" />
            <Label Text="API Key (X-Api-Key header)" FontAttributes="Bold" />
            <Entry Placeholder="Leave blank if auth is disabled" Text="{Binding ApiKey}" />
            <Button Text="Save Settings"
                    Command="{Binding SaveCommand}"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="White" />
            <Label Text="{Binding StatusMessage}" TextColor="Green" />
            <Label Text="{Binding ErrorMessage}" TextColor="Red" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
